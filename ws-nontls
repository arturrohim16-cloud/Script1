#!/usr/bin/env python3
import socket, threading, select, sys, time

# Konfigurasi Utama
LISTENING_ADDR = '0.0.0.0'
try:
    LISTENING_PORT = int(sys.argv[1])
except:
    LISTENING_PORT = 80

# Target internal (Dropbear)
DEFAULT_HOST = '127.0.0.1:109'
BUFLEN = 4096 * 4
TIMEOUT = 60

# Response Header - Support HTML Color untuk HTTP Custom
RESPONSE = b'HTTP/1.1 101 Switching Protocols\r\nUpgrade: websocket\r\nConnection: Upgrade\r\n\r\n'

class Server:
    def __init__(self, host, port):
        self.host = host
        self.port = port
        self.running = False

    def start(self):
        self.soc = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.soc.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            self.soc.bind((self.host, self.port))
        except Exception as e:
            print(f"Gagal Bind ke Port {self.port}: {e}")
            sys.exit(1)
        
        self.soc.listen(100)
        self.running = True
        print(f"Proxy Running on {self.host}:{self.port}")
        
        try:
            while self.running:
                client, addr = self.soc.accept()
                threading.Thread(target=self.handler, args=(client, addr), daemon=True).start()
        except KeyboardInterrupt:
            self.running = False
            self.soc.close()

    def handler(self, client, addr):
        try:
            data = client.recv(BUFLEN)
            if not data: return
            
            # Mendukung pengecekan header sederhana
            if b'Upgrade: websocket' in data or b'GET' in data:
                target = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                host, port = DEFAULT_HOST.split(':')
                target.connect((host, int(port)))
                
                # Kirim balasan 101 ke HTTP Custom
                client.sendall(RESPONSE)
                
                # Forwarding data dua arah (Bridge)
                self.forward(client, target)
        except:
            pass
        finally:
            client.close()

    def forward(self, source, destination):
        def bridge(src, dst):
            try:
                while True:
                    data = src.recv(BUFLEN)
                    if not data: break
                    dst.sendall(data)
            except:
                pass
            finally:
                src.close()
                dst.close()

        threading.Thread(target=bridge, args=(source, destination), daemon=True).start()
        bridge(destination, source)

if __name__ == '__main__':
    print("\n:------- AJI SYSTEM PROXY -------:\n")
    proxy = Server(LISTENING_ADDR, LISTENING_PORT)
    proxy.start()
